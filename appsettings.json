{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=netsentinel.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "NetSentinel": {
    "SubnetBase": "192.168.1",
    "ScanRangeStart": 1,
    "ScanRangeEnd": 254,
    "PingTimeoutMs": 500,
    "TrafficSpikeThresholdMB": 50.0,
    "ScanIntervalSeconds": 60
  }
}
