@{ ViewData["Title"] = "Devices"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="panel panel-full">
    <div class="panel-head">
        ALL DEVICES
        <div class="panel-actions">
            <input type="text" class="scan-input" id="searchBox" placeholder="Search IP, MAC, hostname..." style="width:220px;padding:4px 8px;font-size:11px" oninput="filterDevices()" />
            <button class="btn-sm active" onclick="filterBy('all')" id="btnAll">ALL</button>
            <button class="btn-sm" onclick="filterBy('online')" id="btnOnline">ONLINE</button>
            <button class="btn-sm" onclick="filterBy('unknown')" id="btnUnknown">UNKNOWN</button>
            <button class="btn-sm" onclick="triggerScan()">▶ SCAN</button>
        </div>
    </div>
    <table class="data-table" id="deviceTable">
        <thead>
            <tr>
                <th>STATUS</th>
                <th>IP ADDRESS</th>
                <th>MAC ADDRESS</th>
                <th>HOSTNAME / LABEL</th>
                <th>TRUSTED</th>
                <th>LAST SEEN</th>
                <th>ACTIONS</th>
            </tr>
        </thead>
        <tbody id="deviceTbody">
            <tr><td colspan="7" style="text-align:center;padding:24px;color:var(--dim)">Loading devices...</td></tr>
        </tbody>
    </table>
</div>

@section Scripts {
<script>
let allDevices = [];
let currentFilter = 'all';

async function loadDevices() {
    const res = await fetch('/api/devices');
    allDevices = await res.json();
    renderDevices(allDevices);
}

function filterBy(f) {
    currentFilter = f;
    ['all','online','unknown'].forEach(x => document.getElementById('btn'+x.charAt(0).toUpperCase()+x.slice(1))?.classList.remove('active'));
    document.getElementById('btn'+f.charAt(0).toUpperCase()+f.slice(1))?.classList.add('active');
    applyFilters();
}

function filterDevices() { applyFilters(); }

function applyFilters() {
    const q = document.getElementById('searchBox').value.toLowerCase();
    let devs = allDevices;
    if (currentFilter === 'online') devs = devs.filter(d => d.isOnline);
    if (currentFilter === 'unknown') devs = devs.filter(d => !d.isKnown && d.isOnline);
    if (q) devs = devs.filter(d =>
        d.ipAddress.includes(q) || d.macAddress.toLowerCase().includes(q) ||
        (d.hostname||'').toLowerCase().includes(q) || (d.deviceLabel||'').toLowerCase().includes(q));
    renderDevices(devs);
}

function renderDevices(devs) {
    const tbody = document.getElementById('deviceTbody');
    if (!devs.length) { tbody.innerHTML='<tr><td colspan="7" style="text-align:center;padding:24px;color:var(--dim)">No devices found</td></tr>'; return; }
    tbody.innerHTML = devs.map(d => `
        <tr>
            <td><div class="dot ${d.isOnline?'dot-green':'dot-red'}" style="display:inline-block;margin-right:6px"></div>${d.isOnline?'<span class="ok">Online</span>':'<span class="muted">Offline</span>'}</td>
            <td style="font-family:var(--mono);color:var(--blue)">${d.ipAddress}</td>
            <td style="font-family:var(--mono);color:var(--dim)">${d.macAddress}</td>
            <td>${d.deviceLabel ? '<span class="ok">'+d.deviceLabel+'</span>' : (d.hostname||'Unknown')} ${!d.isKnown?'<span class="badge badge-warn">UNKNOWN</span>':''}</td>
            <td>${d.isKnown ? '<span class="ok">✔ Trusted</span>' : '<span class="danger">✗ Unknown</span>'}</td>
            <td style="color:var(--muted)">${new Date(d.lastSeen).toLocaleString()}</td>
            <td>
                <div style="display:flex;gap:4px">
                    ${!d.isKnown ? `<button class="dev-btn trust" onclick="trustDevice(${d.id})">TRUST</button>` : ''}
                    <button class="dev-btn" onclick="labelDevice(${d.id}, '${d.deviceLabel||''}')">LABEL</button>
                    <button class="dev-btn" onclick="scanPorts('${d.ipAddress}')">PORTS</button>
                    <button class="dev-btn" style="color:var(--danger);border-color:#4a1a1a" onclick="deleteDevice(${d.id})">DEL</button>
                </div>
            </td>
        </tr>`).join('');
}

async function trustDevice(id) {
    await fetch(`/api/devices/${id}/trust`, {method:'PUT'});
    showToast('Device marked as trusted', 'ok');
    loadDevices();
}

async function labelDevice(id, current) {
    const label = prompt('Enter a label for this device:', current);
    if (label === null) return;
    await fetch(`/api/devices/${id}/label`, {method:'PUT', headers:{'Content-Type':'application/json'}, body:JSON.stringify(label)});
    showToast('Label saved', 'ok');
    loadDevices();
}

function scanPorts(ip) {
    window.location = `/PortScanner/Index?ip=${ip}`;
}

async function deleteDevice(id) {
    if (!confirm('Remove this device from the database?')) return;
    await fetch(`/api/devices/${id}`, {method:'DELETE'});
    showToast('Device removed', 'warn');
    loadDevices();
}

loadDevices();
</script>
}
