@model List<NetSentinel.Models.LogEntry>
@{
    ViewData["Title"] = "Logs";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-title">SYSTEM LOGS</div>
    <div class="last-scan">@Model.Count entries</div>
</div>

<div class="panel" style="margin-bottom:0">
    <div class="panel-head">
        LOG HISTORY
        <span class="badge badge-info">Last 200 entries</span>
    </div>
    <div class="log-table">
        @if (!Model.Any())
        {
            <div class="empty-state">No log entries yet. Run a scan to generate logs.</div>
        }
        else
        {
            @foreach (var log in Model)
            {
                <div class="log-row">
                    <span class="log-time">@log.Timestamp.ToString("HH:mm:ss")</span>
                    <span class="log-level log-@log.Level.ToLower()">[@log.Level]</span>
                    <span class="log-source">@log.Source</span>
                    <span class="log-msg log-@log.Level.ToLower()">@log.Message</span>
                </div>
            }
        }
    </div>
</div>
