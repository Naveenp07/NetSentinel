@model NetSentinel.Models.DashboardStats
@{ ViewData["Title"] = "Dashboard"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="page-header">
    <div class="page-title">DASHBOARD</div>
    <div class="last-scan">Last scan: <span id="lastScan">@(Model.LastScan == DateTime.MinValue ? "Never" : Model.LastScan.ToString("HH:mm:ss"))</span></div>
</div>

<div class="stat-row">
    <div class="stat-card"><div class="stat-label">DEVICES</div><div class="stat-val" id="totalDevices">@Model.TotalDevices</div><div class="stat-sub">total tracked</div></div>
    <div class="stat-card"><div class="stat-label">ONLINE</div><div class="stat-val ok" id="onlineDevices">@Model.OnlineDevices</div><div class="stat-sub muted">@Model.OfflineDevices offline</div></div>
    <div class="stat-card"><div class="stat-label">ALERTS</div><div class="stat-val danger" id="alertCount">@Model.ActiveAlerts</div><div class="stat-sub warn">unacknowledged</div></div>
    <div class="stat-card"><div class="stat-label">TRAFFIC</div><div class="stat-val info" id="trafficStat">--</div><div class="stat-sub muted" id="trafficSub">MB/s</div></div>
</div>

<div class="panels">
    <div class="panel">
        <div class="panel-head">DEVICES <span class="badge badge-info" id="devBadge">@Model.TotalDevices found</span></div>
        <div id="deviceList"><div class="empty-state">Run a scan to discover devices</div></div>
    </div>
    <div class="panel">
        <div class="panel-head">ALERTS <span class="badge badge-warn" id="alertBadgePanel">@Model.ActiveAlerts active</span></div>
        <div id="alertList"><div class="empty-state">No active alerts</div></div>
    </div>
</div>

<div class="panels">
    <div class="panel">
        <div class="panel-head">LIVE TRAFFIC</div>
        <div class="traffic-bars">
            <div class="bar-group"><div class="bar-label"><span>HTTP</span><span id="httpMb">-- MB/s</span></div><div class="bar-track"><div class="bar-fill bar-blue" id="httpBar" style="width:0%"></div></div></div>
            <div class="bar-group"><div class="bar-label"><span>DNS</span><span id="dnsMb">-- MB/s</span></div><div class="bar-track"><div class="bar-fill bar-green" id="dnsBar" style="width:0%"></div></div></div>
            <div class="bar-group"><div class="bar-label"><span>OTHER</span><span id="otherMb">-- MB/s</span></div><div class="bar-track"><div class="bar-fill bar-orange" id="otherBar" style="width:0%"></div></div></div>
        </div>
        <div class="wave-container" id="wave"></div>
    </div>
    <div class="panel">
        <div class="panel-head">LIVE LOGS</div>
        <div id="liveLog" class="live-log"></div>
    </div>
</div>

@section Scripts {
<script>
async function loadDevices() {
    const r = await fetch('/api/devices'); const devs = await r.json();
    const el = document.getElementById('deviceList');
    if (!devs.length) { el.innerHTML='<div class="empty-state">No devices. Run a scan.</div>'; return; }
    el.innerHTML = devs.slice(0,8).map(d=>`
        <div class="device-row">
            <div class="dot ${d.isOnline?'dot-green':'dot-red'}"></div>
            <div class="dev-info">
                <div class="dev-name">${d.deviceLabel||d.hostname||'Unknown'} ${!d.isKnown?'<span class="badge badge-warn">UNKNOWN</span>':''}</div>
                <div class="dev-ip">${d.ipAddress}</div>
            </div>
            <div class="dev-mac">${d.macAddress}</div>
        </div>`).join('');
    document.getElementById('totalDevices').textContent = devs.length;
    document.getElementById('onlineDevices').textContent = devs.filter(d=>d.isOnline).length;
    document.getElementById('devBadge').textContent = devs.length+' found';
}
async function loadAlerts() {
    const r = await fetch('/api/alerts?unacknowledgedOnly=true'); const alerts = await r.json();
    document.getElementById('alertCount').textContent = alerts.length;
    document.getElementById('alertBadgePanel').textContent = alerts.length+' active';
    const b = document.getElementById('alertBadge');
    b.style.display = alerts.length?'inline':'none'; b.textContent = alerts.length;
    const el = document.getElementById('alertList');
    if (!alerts.length) { el.innerHTML='<div class="empty-state">No active alerts</div>'; return; }
    el.innerHTML = alerts.slice(0,5).map(a=>`
        <div class="alert-row">
            <div class="alert-icon ${a.severity===2?'alert-danger-bg':'alert-warn-bg'}">${a.severity===2?'!':'↑'}</div>
            <div class="alert-text"><strong>${a.type}</strong><br>${a.message}</div>
            <div class="alert-time">${new Date(a.timestamp).toLocaleTimeString()}</div>
        </div>`).join('');
}
async function loadTraffic() {
    const r = await fetch('/api/traffic/stats'); const s = await r.json();
    document.getElementById('trafficStat').textContent = s.totalMbps.toFixed(1);
    document.getElementById('trafficSub').textContent = s.totalMbps > 10 ? '⚠ spike!' : 'MB/s normal';
    document.getElementById('httpMb').textContent = s.httpMbps.toFixed(2)+' MB/s';
    document.getElementById('dnsMb').textContent  = s.dnsMbps.toFixed(2)+' MB/s';
    document.getElementById('otherMb').textContent= s.otherMbps.toFixed(2)+' MB/s';
    const max = Math.max(s.totalMbps,0.01);
    document.getElementById('httpBar').style.width  = Math.min(100,s.httpMbps/max*100)+'%';
    document.getElementById('dnsBar').style.width   = Math.min(100,s.dnsMbps/max*100)+'%';
    document.getElementById('otherBar').style.width = Math.min(100,s.otherMbps/max*100)+'%';
    if (s.waveData) {
        const cols = document.getElementById('wave').querySelectorAll('.wave-col');
        s.waveData.forEach((v,i)=>{ if(cols[i]) cols[i].style.height=Math.min(48,Math.max(4,v/2))+'px'; });
    }
}
// Wave init
const wave = document.getElementById('wave');
for(let i=0;i<25;i++){const c=document.createElement('div');c.className='wave-col';c.style.height=Math.floor(Math.random()*28+8)+'px';wave.appendChild(c);}
// SignalR
const conn = new signalR.HubConnectionBuilder().withUrl('/networkHub').build();
conn.on('ReceiveAlert', a => { showToast('⚠ '+a.message,'warn'); loadAlerts(); });
conn.on('ReceiveDeviceList', () => loadDevices());
conn.start().catch(e => console.warn('SignalR:', e));
// Init
loadDevices(); loadAlerts();
setInterval(()=>{loadTraffic();},3000);
setInterval(loadAlerts,10000);
</script>
}
